    },
    "mobile-web": {
      "resourceRoot": "src/mobile-web/src/i18n",
      "loading": "surface-minimal"
    },
    "installer": {
      "resourceRoot": "BitFun-Installer/src/i18n/locales",
      "loading": "surface-minimal"
    },
    "core": {
      "resourceRoot": "src/crates/assembly/core/locales",
      "loading": "backend-service"
    },
    "relay-static-homepage": {
      "resourceRoot": "src/apps/relay-server/static/homepage",
      "loading": "self-contained-static"
    }
  },
  "locales": [
    {
      "id": "zh-CN",
      "rustVariant": "ZhCN",
      "name": "简体中文",
      "englishName": "Simplified Chinese",
      "nativeName": "简体中文",
      "shortName": "中",
      "rtl": false,
      "dateFormat": "YYYY年MM月DD日",
      "numberFormat": {
        "decimal": ".",
        "thousands": ","
      },
      "aliases": [
        "zh",
        "zh-Hans",
        "zh-CN"
      ],
      "contentFallbacks": [
        "en-US"
      ],
      "modelLanguageName": "Simplified Chinese",
      "shortModelInstruction": "使用简体中文",
      "installer": {
        "uiCode": "zh",
