{
  "version": 1,
  "defaultLocale": "zh-CN",
  "fallbackLocale": "en-US",
  "unknownLocaleFallbackChain": [
    "en-US",
    "zh-CN"
  ],
  "surfaceDefaults": {
    "web-ui": "zh-CN",
    "mobile-web": "en-US",
    "installer": "en-US",
    "core": "zh-CN"
  },
  "surfaceOrders": {
    "web-ui": [
      "zh-CN",
      "en-US",
      "zh-TW"
    ],
    "mobile-web": [
      "zh-CN",
      "zh-TW",
      "en-US"
    ],
    "installer": [
      "en-US",
      "zh-CN",
      "zh-TW"
    ],
    "core": [
      "zh-CN",
      "zh-TW",
      "en-US"
    ]
  },
  "surfaces": {
    "web-ui": {
      "resourceRoot": "src/web-ui/src/locales",
